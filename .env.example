# Flask 配置
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-random-secret-key-here-change-this-in-production

# MongoDB 数据库配置
# 本地 MongoDB 示例：mongodb://localhost:27017/database_name
# 带认证示例：mongodb://username:password@localhost:27017/database_name
# MongoDB Atlas 云服务示例：mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb://localhost:27017/station_agent_db
DATABASE_NAME=station_agent_db

# 邮件服务配置（以 QQ 邮箱为例）
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USERNAME=your-qq-email@qq.com
MAIL_PASSWORD=your-smtp-authorization-code

# 应用运行配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

